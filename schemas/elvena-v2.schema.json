{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Elvena v2 Event",
  "description": "Elwisp to Elnis event payload",
  "type": "object",
  "required": ["version", "elwisp", "source", "id", "mode", "content", "targets"],
  "properties": {
    "version": {
      "type": "string",
      "const": "elvena.v2"
    },
    "elwisp": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["record", "direct", "llm"]
    },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "format": {
      "type": "string",
      "enum": ["text", "elyph", "markdown"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "model_slot": {
      "type": "string",
      "enum": ["elwisp1", "elwisp2", "elwisp3"]
    },
    "tool_list_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tools": { "type": "object" },
    "meta": { "type": "object" },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["platform"],
        "properties": {
          "platform": { "type": "string" },
          "type": { "type": "string" },
          "id": { "type": "string" }
        }
      }
    }
  }
}
